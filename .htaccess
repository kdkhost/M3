AddType application/manifest+json .webmanifest .json
# Configuração específica para módulos
<IfModule php8_module>
   php_value error_reporting 0
   php_flag display_errors Off
   php_flag log_errors Off
   php_value max_execution_time 3000
   php_value max_input_time 600
   php_value max_input_vars 1000
   php_value memory_limit 128M
   php_value post_max_size 32M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php82"
   php_value upload_max_filesize 32M
   php_flag zlib.output_compression Off
</IfModule>

<IfModule lsapi_module>
   php_value error_reporting 0
   php_flag display_errors Off
   php_flag log_errors Off
   php_value max_execution_time 3000
   php_value max_input_time 600
   php_value max_input_vars 1000
   php_value memory_limit 128M
   php_value post_max_size 32M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php82"
   php_value upload_max_filesize 32M
   php_flag zlib.output_compression Off
</IfModule>

ErrorDocument 404 /erro/index.html

# php -- BEGIN cPanel-generated handler, do not edit
# Defina o pacote “ea-php82” como a linguagem padrão de programação “PHP”.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
